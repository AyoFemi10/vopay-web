      "namedRegex": "^/auth/signup(?:/)?$"
    },
    {
      "page": "/auth/verify",
      "regex": "^/auth/verify(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/verify(?:/)?$"
    },
    {
      "page": "/contact",
